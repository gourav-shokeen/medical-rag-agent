# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Active corpus: "medical" (default, chroma_med/)
CORPUS=medical

# LLM provider for the agent: "ollama" (local) or "groq" (hosted)
LLM_PROVIDER=ollama

# Required when LLM_PROVIDER=groq
GROQ_API_KEY=

# Ollama chat model used when LLM_PROVIDER=ollama
# (embeddings always use local Ollama nomic-embed-text, matching the existing index)
OLLAMA_MODEL=llama3.1:8b

# Langfuse tracing (optional — agent runs fine without these)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
